# Database
DATABASE_URL=postgresql+asyncpg://realestate:realestate@localhost:5432/realestate

# Redis
REDIS_URL=redis://localhost:6379/0

# Domain.com.au API (register at developer.domain.com.au)
DOMAIN_CLIENT_ID=your-client-id-here
DOMAIN_CLIENT_SECRET=your-client-secret-here

# Admin API key (protects /api/v1/admin endpoints)
ADMIN_API_KEY=change-me-to-a-random-secret

# Data directory for bulk CSV files (valuer_general/, nsw_sales/)
# In Docker this is auto-set to /data via the volume mount — only set this for local dev outside Docker
# DATA_DIR=./data

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Frontend env (Next.js — prefix with NEXT_PUBLIC_ to expose to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
